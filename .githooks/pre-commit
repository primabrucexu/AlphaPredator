#!/usr/bin/env sh
set -eu

# Block forbidden import patterns in staged Python files.
# Rule source: docs/code-style.md

staged_files=$(git diff --cached --name-only --diff-filter=ACMR | grep -E '\.py$' || true)

if [ -z "$staged_files" ]; then
  exit 0
fi

optional_import_violations=""
inline_import_violations=""

for file in $staged_files; do
  if ! git cat-file -e ":$file" 2>/dev/null; then
    continue
  fi

  if matches=$(git show ":$file" | awk '
    function indent_len(s,  i, c, n) {
      n = 0
      for (i = 1; i <= length(s); i++) {
        c = substr(s, i, 1)
        if (c == " " || c == "\t") {
          n++
        } else {
          break
        }
      }
      return n
    }

    {
      line = $0
      curr_indent = indent_len(line)

      if (line ~ /^[ \t]*try:[ \t]*(#.*)?$/) {
        in_try = 1
        try_indent = curr_indent
        saw_import = 0
        next
      }

      if (in_try == 1) {
        if (line !~ /^[ \t]*$/ && curr_indent <= try_indent) {
          in_try = 0
          saw_import = 0
        }
      }

      if (in_try == 1) {
        if (line ~ /^[ \t]*(from[ \t]+[^ \t]+[ \t]+import[ \t]+|import[ \t]+[^ \t]+)/) {
          saw_import = 1
        }

        if (saw_import == 1 && line ~ /^[ \t]*except[ \t]+(ImportError|Exception)([ \t]+as[ \t]+[A-Za-z_][A-Za-z0-9_]*)?[ \t]*:/) {
          print NR ":" line
          found = 1
        }
      }
    }

    END {
      if (found == 1) {
        exit 0
      }
      exit 1
    }
  '); then
    optional_import_violations="$optional_import_violations\n$file\n$matches\n"
  fi

  if inline_matches=$(git show ":$file" | awk '
    {
      line = $0
      if (line ~ /^[ \t]+(import[ \t]+[^ \t]+|from[ \t]+[^ \t]+[ \t]+import[ \t]+)/) {
        print NR ":" line
        found = 1
      }
    }

    END {
      if (found == 1) {
        exit 0
      }
      exit 1
    }
  '); then
    inline_import_violations="$inline_import_violations\n$file\n$inline_matches\n"
  fi
done

if [ -n "$optional_import_violations" ]; then
  printf "\n[code-style] Commit blocked: detected forbidden optional-import fallback pattern.\n"
  printf "Rule: docs/code-style.md\n"
  printf "Please change to direct import and let missing dependency fail fast.\n"
  printf "%b\n" "$optional_import_violations"
  exit 1
fi

if [ -n "$inline_import_violations" ]; then
  printf "\n[code-style] Commit blocked: detected non-top-level import statements.\n"
  printf "Rule: docs/code-style.md\n"
  printf "Please move imports to the file header.\n"
  printf "%b\n" "$inline_import_violations"
  exit 1
fi

exit 0
