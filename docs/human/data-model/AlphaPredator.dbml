Table stock_list [headercolor: #175e7a] {
	full_code varchar(255) [ pk, unique, note: '带交易所的完整股票代码。如000001.SZ' ]
	code varchar(255) [ unique, note: '6位数字股票代码（6位，如 `000001`）' ]
	name varchar(255) [ note: '股票名称' ]
	is_st boolean [ note: '是否ST，获取方式：通过name字段中包含`ST``。' ]
	cnspell varchar(255) [ note: '股票名称拼音简称' ]
	market varchar(255) [ note: '所属市场，有且仅有四个：主板、创业板、科创板、北交所' ]

	indexes {
		(name, cnspell, code) [ name: 'stock_list_index_0' ]
	}

	Note: '股票列表'
}

Table daily_hot_pic [headercolor: #175e7a] {
	id integer [ pk, increment ]
	trade_date varchar(255) [ not null, note: '交易日期，也就是图片复盘的是那天的涨停' ]
	summary_image_url varchar(255) [ not null, note: '简图外部url访问地址' ]
	source varchar(255) [ not null, note: '数据来源，目前只有韭研公社，填写为jygs' ]

	Note: '涨停复盘简图'
}

Table daily_hot_info [headercolor: #175e7a] {
	id integer [ pk, increment ]
	trade_date date [ not null, note: '交易日期 YYYYMMDD' ]
	limit_up_time text [ not null, note: '涨停时间' ]
	stock_code varchar(255) [ not null, note: '6位数字的股票代码' ]
	name varchar(255) [ not null, note: '股票名称' ]
	streak_text varchar(255) [ not null, note: '连板信息文本，如“两天两板”，无内容则表示首次涨停' ]
	hot_theme varchar(255) [ not null, note: '涨停题材' ]
	reason text [ not null, note: '涨停解析内容' ]
	source varchar(255) [ not null, note: '数据来源，目前只有韭研公社，填写为jygs' ]
	short_reason text(65535) [ not null, note: '从涨停简图中OCR识别得到的一句话涨停原因' ]

	Note: '涨停解析'
}

Table task_info [headercolor: #175e7a] {
	id integer [ pk, increment, unique ]
	task_id varchar(255)
	start_date date [ not null, note: '数据起始日期 YYYYMMDD' ]
	end_date date [ not null, note: '数据截至日期 YYYYMMDD' ]
	status varchar(255) [ not null, default: PENDING, note: '任务状态。PENDING、RUNNING、FAILED、SUCCESS、TERMINATED' ]
	total_items integer [ not null, note: '所有子任务数量' ]
	processed_items integer [ not null, note: '已完成子任务数量' ]
	current_label varchar(255) [ not null, note: '当前正在处理的项标签：MARKET_DATA 时为股票代码如 000001.SZ，JYGS_REVIEW 时为日期如 20241101，STOCK_LIST_SYNC 时为空' ]
	error_message text [ not null ]
	task_type varchar(255) [ not null, default: MARKET_DATA, note: '任务类型。当前仅有JYGS_REVIEW（韭研公社涨停信信息复盘）MARKET_DATA_LOAD（市场天级交易数据拉取）' ]
	task_start_date datetime [ note: '任务开始时间 YYYYMMDD HH:mm:ss' ]
	task_end_date datetime [ note: '任务结束时间 YYYYMMDD HH:mm:ss' ]
}

Table user_trade_history [headercolor: #175e7a] {
	id integer [ pk, increment, not null ]
	trade_date date [ note: '交易日期 YYYYMMDD格式' ]
	stock_code varchar(255) [ note: '6位数字股票代码' ]
	stock_name varchar(255) [ note: '股票名称' ]
	operate_price numeric [ not null, note: '买入价格' ]
	operate_type integer [ note: '操作类型，0买入，1卖出' ]
	amount integer [ note: '买入或者卖出的股票数量' ]
	reason text(65535) [ not null, note: '操作原因' ]
	create_time datetime [ not null, note: '个人分析评价' ]

	indexes {
		(stock_code, stock_name) [ name: 'user_trade_history_index_0' ]
	}

	Note: '用户交易历史'
}

Table model_info [headercolor: #175e7a] {
	id integer [ pk, increment, not null ]
	provider varchar(255) [ note: '大模型提供商' ]
	model_name varchar(255) [ note: '模型名称' ]
	api_url text(65535) [ note: 'api访问地址' ]
	sk text(65535) [ note: 'api key' ]
	api_type varchar(255) [ note: 'api模式，是open ai格式的还是anthropic格式的api' ]

	Note: '大模型信息'
}

Table day_level_trade_data [headercolor: #175e7a] {
	full_code varchar(255) [ not null, note: '带交易所后缀的6位数字格式股票代码，如 000001.SZ' ]
	trade_date date [ not null, note: '交易日期，YYYYMMDD' ]
	open numeric [ not null, note: '开盘价' ]
	high numeric [ not null, note: '最高价' ]
	low numeric [ not null, note: '最低价' ]
	close numeric [ not null, note: '收盘价' ]
	pre_close numeric [ not null, note: '昨日收盘价' ]
	change numeric [ not null, note: '涨跌额' ]
	pct_chg numeric [ not null, note: '涨跌幅（%）' ]
	vol numeric [ not null, note: '成交量，单位是手，也就是100股' ]
	amount numeric [ not null, note: '成交额，单位是亿元' ]
	is_up_limit boolean [ not null, note: '该日是否涨停' ]
	is_down_limit boolean [ not null, note: '该日是否跌停' ]
	is_stop boolean [ not null, note: '是否停牌' ]

	indexes {
		(full_code, trade_date) [ name: 'day_level_trade_data_index_0', unique ]
	}

	Note: '股票日级别交易数据'
}

Table 5m_level_trade_data [headercolor: #175e7a] {
	full_code varchar(255) [ not null, note: '带交易所后缀的6位数字格式股票代码，如 000001.SZ' ]
	trade_date date [ not null, note: '交易日期，YYYY-MM-DD HH:mm:ss' ]
	open numeric [ not null, note: '开盘价' ]
	high numeric [ not null, note: '最高价' ]
	low numeric [ not null, note: '最低价' ]
	close numeric [ not null, note: '收盘价' ]
	pre_close numeric [ not null, note: '上根k线的收盘价' ]
	change numeric [ not null, note: '涨跌额' ]
	pct_chg numeric [ not null, note: '涨跌幅（%）' ]
	vol numeric [ not null, note: '成交量，单位是手，也就是100股' ]
	amount numeric [ not null, note: '成交额，单位是元' ]
	is_up_limit boolean [ not null, note: '该日是否涨停' ]
	is_down_limit boolean [ not null, note: '该日是否跌停' ]
	is_stop boolean [ not null, note: '是否停牌' ]

	indexes {
		(full_code, trade_date) [ name: 'day_level_trade_data_index_0', unique ]
	}

	Note: '股票日级别交易数据'
}

Table review_note [headercolor: #175e7a] {
	id integer [ pk, increment, not null ]
	trade_id integer
	analyse text(65535) [ not null, note: '用户分析' ]
	score integer [ not null, note: '操作评价，1-10' ]
	is_model_analyse boolean [ note: '是否为模型生成的复盘内容' ]
	model_id integer [ note: '模型id，空表示用户输入的复盘内容' ]

	Note: '复盘笔记'
}

Table user_stock_pick_sample [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '样本ID，建议使用UUID' ]
	user_id varchar(255) [ not null, note: '用户ID，当前可单用户，保留多用户扩展' ]
	stock_code varchar(255) [ not null, note: '6位股票代码，如000001' ]
	pick_date date [ not null, note: '选股日期，YYYYMMDD' ]
	horizon_days integer [ not null, default: 5, note: '评估窗口天数，如3/5/10' ]
	entry_price numeric [ note: '参考买入价，可为空' ]
	exit_price numeric [ note: '参考卖出价，可为空' ]
	manual_label varchar(255) [ note: '人工标签，如龙头接力/趋势低吸' ]
	pick_reason text [ note: '用户记录的选股理由' ]
	result_return_pct numeric [ note: '该样本最终收益率(%)，可后补' ]
	result_max_drawdown_pct numeric [ note: '该样本最大回撤(%)，可后补' ]
	source_type varchar(255) [ not null, default: manual, note: '样本来源：manual/import/api' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]
	updated_at datetime [ not null, note: '更新时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(user_id, pick_date) [ name: 'idx_user_pick_sample_user_date' ]
		(stock_code, pick_date) [ name: 'idx_user_pick_sample_stock_date' ]
	}

	Note: '用户历史选股样本主表'
}

Table user_stock_pick_feature [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '特征记录ID，建议使用UUID' ]
	sample_id varchar(255) [ not null, note: '关联样本ID，指向user_stock_pick_sample.id' ]
	trade_date date [ not null, note: '特征对应交易日，通常与pick_date一致' ]
	feature_key varchar(255) [ not null, note: '特征键，如ma5_above_ma20/turnover_rate' ]
	feature_value_num numeric [ note: '数值型特征值，可为空' ]
	feature_value_text text [ note: '文本型特征值，可为空' ]
	feature_group varchar(255) [ note: '特征分组，如price/volume/sentiment' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(sample_id, feature_key) [ name: 'uq_user_pick_feature_sample_key', unique ]
		(feature_key, trade_date) [ name: 'idx_user_pick_feature_key_date' ]
	}

	Note: '样本特征快照（Key-Value）'
}

Table user_pattern_model [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '模式ID，建议使用UUID' ]
	user_id varchar(255) [ not null, note: '用户ID' ]
	name varchar(255) [ not null, note: '模式名称' ]
	description text [ note: '模式描述与解释' ]
	status varchar(255) [ not null, default: active, note: '模式状态：active/draft/archived' ]
	source_scope varchar(255) [ not null, default: personal, note: '模式作用域：personal/global' ]
	version integer [ not null, default: 1, note: '模式版本号，便于迭代' ]
	quality_score numeric [ note: '模式质量分（可基于回测结果计算）' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]
	updated_at datetime [ not null, note: '更新时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(user_id, status) [ name: 'idx_user_pattern_model_user_status' ]
		(user_id, name, version) [ name: 'uq_user_pattern_model_user_name_version', unique ]
	}

	Note: '用户选股模式主表'
}

Table user_pattern_rule [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '规则ID，建议使用UUID' ]
	pattern_id varchar(255) [ not null, note: '所属模式ID，指向user_pattern_model.id' ]
	rule_order integer [ not null, note: '规则顺序，从1递增' ]
	feature_key varchar(255) [ not null, note: '规则作用的特征键' ]
	operator varchar(255) [ not null, note: '比较符，如>/>=/</<=/=/in/between' ]
	threshold_num_min numeric [ note: '数值阈值下界，单阈值或区间下界' ]
	threshold_num_max numeric [ note: '数值阈值上界，between场景使用' ]
	threshold_text text [ note: '文本阈值，in/枚举类判断使用' ]
	weight numeric [ not null, default: 1, note: '规则权重，软评分时使用' ]
	is_required boolean [ not null, default: true, note: '是否硬条件，true表示必须满足' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(pattern_id, rule_order) [ name: 'uq_user_pattern_rule_pattern_order', unique ]
	}

	Note: '模式规则明细表（可解释、可回测）'
}

Table user_pattern_backtest_job [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '回测任务ID，建议使用UUID' ]
	pattern_id varchar(255) [ not null, note: '回测的模式ID，指向user_pattern_model.id' ]
	user_id varchar(255) [ not null, note: '任务归属用户ID' ]
	start_date date [ not null, note: '回测起始日期 YYYYMMDD' ]
	end_date date [ not null, note: '回测结束日期 YYYYMMDD' ]
	universe_scope varchar(255) [ not null, default: all_a, note: '回测股票池范围，如all_a/主板/自选' ]
	status varchar(255) [ not null, default: pending, note: '任务状态：pending/running/success/failed' ]
	error_message text [ note: '失败原因，成功时可为空' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]
	updated_at datetime [ not null, note: '更新时间 YYYYMMDD HH:mm:ss' ]
	finished_at datetime [ note: '完成时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(pattern_id, status) [ name: 'idx_user_pattern_backtest_job_pattern_status' ]
		(user_id, created_at) [ name: 'idx_user_pattern_backtest_job_user_created' ]
	}

	Note: '模式回测任务表'
}

Table user_pattern_backtest_metric [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '回测指标记录ID，建议使用UUID' ]
	job_id varchar(255) [ not null, note: '关联回测任务ID，指向user_pattern_backtest_job.id' ]
	metric_key varchar(255) [ not null, note: '指标键，如annual_return/win_rate/sharpe/max_dd' ]
	metric_value numeric [ not null, note: '指标数值' ]
	metric_text text [ note: '指标附加文本说明，可为空' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(job_id, metric_key) [ name: 'uq_user_pattern_backtest_metric_job_key', unique ]
	}

	Note: '回测指标结果表'
}

Table user_pattern_suggestion [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '建议ID，建议使用UUID' ]
	user_id varchar(255) [ not null, note: '建议归属用户ID' ]
	pattern_id varchar(255) [ note: '来源模式ID，可为空（多模式融合时）' ]
	trade_date date [ not null, note: '建议交易日 YYYYMMDD' ]
	stock_code varchar(255) [ not null, note: '建议股票代码（6位）' ]
	score numeric [ not null, note: '建议评分，用于排序' ]
	reason_summary text [ note: '建议理由摘要' ]
	risk_note text [ note: '风险提示' ]
	action_hint varchar(255) [ note: '动作建议，如观察/低吸/回避' ]
	status varchar(255) [ not null, default: active, note: '建议状态：active/expired/archived' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(user_id, trade_date) [ name: 'idx_user_pattern_suggestion_user_date' ]
		(stock_code, trade_date) [ name: 'idx_user_pattern_suggestion_stock_date' ]
	}

	Note: 'AI个性化选股建议表'
}

Table user_pattern_feedback [headercolor: #175e7a] {
	id varchar(255) [ pk, unique, note: '反馈ID，建议使用UUID' ]
	suggestion_id varchar(255) [ not null, note: '关联建议ID，指向user_pattern_suggestion.id' ]
	user_id varchar(255) [ not null, note: '反馈用户ID' ]
	feedback_type varchar(255) [ not null, note: '反馈类型：like/dislike/ignore/manual_note' ]
	feedback_score integer [ note: '反馈分值，可选1~5' ]
	feedback_note text [ note: '反馈文本备注' ]
	created_at datetime [ not null, note: '创建时间 YYYYMMDD HH:mm:ss' ]

	indexes {
		(suggestion_id) [ name: 'idx_user_pattern_feedback_suggestion' ]
		(user_id, created_at) [ name: 'idx_user_pattern_feedback_user_time' ]
	}

	Note: '用户对AI建议的反馈闭环表'
}


Ref fk_user_trade_history_id_review_note {
	user_trade_history.id < review_note.trade_id [ delete: no action, update: no action ]
}

Ref fk_user_stock_pick_feature_sample_id_user_stock_pick_sample {
	user_stock_pick_feature.sample_id > user_stock_pick_sample.id [ delete: no action, update: cascade ]
}

Ref fk_user_pattern_rule_pattern_id_user_pattern_model {
	user_pattern_rule.pattern_id > user_pattern_model.id [ delete: no action, update: cascade ]
}

Ref fk_user_pattern_backtest_job_pattern_id_user_pattern_model {
	user_pattern_backtest_job.pattern_id > user_pattern_model.id [ delete: no action, update: cascade ]
}

Ref fk_user_pattern_backtest_metric_job_id_user_pattern_backtest_job {
	user_pattern_backtest_metric.job_id > user_pattern_backtest_job.id [ delete: no action, update: cascade ]
}

Ref fk_user_pattern_suggestion_pattern_id_user_pattern_model {
	user_pattern_suggestion.pattern_id > user_pattern_model.id  [ delete: set null, update: cascade ]
}

Ref fk_user_pattern_feedback_suggestion_id_user_pattern_suggestion {
	user_pattern_feedback.suggestion_id > user_pattern_suggestion.id [ delete: no action, update: cascade ]
}

Ref fk_user_stock_pick_sample_stock_code_stock_list {
	user_stock_pick_sample.stock_code > stock_list.code [ delete: no action, update: no action ]
}

Ref fk_user_pattern_suggestion_stock_code_stock_list {
	user_pattern_suggestion.stock_code > stock_list.code [ delete: no action, update: no action ]
}


// ================================
// 交易复盘系统（Trade Review System）
// 设计文档：docs/agent/trading-review-system-design.md
// 用户决策日期：2026-05-28
// ================================

Table trade_review_session [headercolor: #2c7a4b] {
	id varchar(255) [ pk, unique, note: '复盘主记录ID，建议使用UUID' ]
	stock_code varchar(255) [ not null, note: '6位股票代码，如000001' ]
	stock_name varchar(255) [ not null, note: '股票名称，冗余存储便于展示' ]
	start_date varchar(255) [ not null, note: '建仓日期，YYYY-MM-DD' ]
	end_date varchar(255) [ note: '清仓日期，YYYY-MM-DD；持仓中时可为空' ]
	status varchar(255) [ not null, default: 'open', note: '复盘状态：open（持仓中）/ closed（已清仓）' ]
	total_buy_amount real [ note: '总买入金额（元），聚合字段，可随操作明细变化更新' ]
	total_sell_amount real [ note: '总卖出金额（元），聚合字段' ]
	realized_pnl real [ note: '已实现盈亏（元），聚合字段；持仓中时为已卖出部分盈亏' ]
	return_rate real [ note: '收益率（小数，如 -0.07 表示 -7%），聚合字段' ]
	entry_reason text [ note: '建仓理由，用户主观复盘填写' ]
	entry_expectation text [ note: '建仓时的预期，用户主观复盘填写' ]
	reflection_did_well text [ note: '自我总结：做对了什么' ]
	reflection_did_poorly text [ note: '自我总结：做错了什么' ]
	reflection_redo_plan text [ note: '自我总结：如果重来怎么做' ]
	ai_status varchar(255) [ not null, default: 'pending', note: 'AI分析状态：pending（未生成）/ done（已完成）/ failed（生成失败）' ]
	created_at varchar(255) [ not null, note: '创建时间，ISO 8601格式' ]
	updated_at varchar(255) [ not null, note: '更新时间，ISO 8601格式' ]

	indexes {
		(stock_code, start_date) [ name: 'idx_trade_review_session_stock_date' ]
		(status) [ name: 'idx_trade_review_session_status' ]
	}

	Note: '交易复盘主记录表。一条记录对应一只股票从建仓到清仓的一整轮操作，持仓中（status=open）也可创建记录。'
}

Table trade_review_operation [headercolor: #2c7a4b] {
	id varchar(255) [ pk, unique, note: '操作记录ID，建议使用UUID' ]
	review_id varchar(255) [ not null, note: '关联复盘主表ID，指向 trade_review_session.id' ]
	trade_time varchar(255) [ not null, note: '操作时间，精确到秒，ISO 8601格式' ]
	operation_type varchar(255) [ not null, note: '操作类型：buy（买入）/ sell（卖出）/ add（加仓）/ reduce（减仓）/ t_buy（T+买）/ t_sell（T+卖）' ]
	price real [ not null, note: '成交价格（元）' ]
	quantity integer [ not null, note: '成交数量（股）' ]
	amount real [ not null, note: '成交金额（元）' ]
	source varchar(255) [ not null, default: 'manual', note: '数据来源：ocr（OCR识别后人工确认）/ manual（手工录入）/ import（导入）' ]
	note text [ note: '备注，可选' ]
	sort_index integer [ note: '排序序号，保证同时间多笔操作展示顺序稳定' ]
	created_at varchar(255) [ not null, note: '创建时间，ISO 8601格式' ]
	updated_at varchar(255) [ not null, note: '更新时间，ISO 8601格式' ]

	indexes {
		(review_id, trade_time) [ name: 'idx_trade_review_operation_review_time' ]
	}

	Note: '复盘成交操作明细表。支撑成交时间线展示、盈亏计算与AI客观数据输入。source=ocr 表示来自图片OCR识别并经人工确认。'
}

Table trade_review_decision_note [headercolor: #2c7a4b] {
	id varchar(255) [ pk, unique, note: '决策备注ID，建议使用UUID' ]
	review_id varchar(255) [ not null, note: '关联复盘主表ID，指向 trade_review_session.id' ]
	related_operation_id varchar(255) [ note: '关联的操作记录ID，指向 trade_review_operation.id；可为空，允许只记录决策而不强绑具体操作' ]
	decision_type varchar(255) [ not null, note: '决策类型：add（加仓）/ reduce（减仓）/ sell（卖出）/ t（T+操作）/ other（其他）' ]
	decision_time varchar(255) [ not null, note: '决策时间，ISO 8601格式' ]
	reason text [ not null, note: '决策原因，用户主观填写' ]
	created_at varchar(255) [ not null, note: '创建时间，ISO 8601格式' ]
	updated_at varchar(255) [ not null, note: '更新时间，ISO 8601格式' ]

	indexes {
		(review_id) [ name: 'idx_trade_review_decision_note_review' ]
	}

	Note: '关键操作节点的主观决策原因表。建仓理由是整轮交易级别的（存于主表entry_reason），关键节点在操作中的原因按节点独立记录于此表，支持多条。'
}

Table trade_review_ai_result [headercolor: #2c7a4b] {
	id varchar(255) [ pk, unique, note: 'AI结果ID，建议使用UUID' ]
	result_type varchar(255) [ not null, note: '结果类型：single_review（单标的分析）/ monthly_review（月度总结）' ]
	review_id varchar(255) [ note: '关联单标的复盘主表ID，指向 trade_review_session.id；月度结果时为空' ]
	month_key varchar(255) [ note: '月份键，格式 YYYY-MM，如 2026-05；单标的结果时为空' ]
	model_name varchar(255) [ note: '使用的AI模型名称，便于追溯和对比不同模型效果' ]
	input_payload_json text [ note: 'AI输入内容快照（JSON字符串），用于复现、调试和版本对比' ]
	output_payload_json text [ note: 'AI输出结果（JSON字符串），字段结构见设计文档第5节' ]
	status varchar(255) [ not null, default: 'done', note: '生成状态：done（成功）/ failed（失败）' ]
	error_message text [ note: '失败时的错误信息，成功时为空' ]
	created_at varchar(255) [ not null, note: '创建时间，ISO 8601格式' ]

	indexes {
		(review_id, result_type) [ name: 'idx_trade_review_ai_result_review_type' ]
		(month_key, result_type) [ name: 'idx_trade_review_ai_result_month_type' ]
	}

	Note: 'AI复盘结果表。统一保存单标的AI分析与月度AI总结，支持重新生成与历史版本追溯。'
}

Table trade_review_monthly_summary [headercolor: #2c7a4b] {
	month_key varchar(255) [ pk, unique, note: '月份主键，格式 YYYY-MM，如 2026-05' ]
	trade_count integer [ not null, note: '本月交易次数（复盘记录数，含 open 和 closed）' ]
	win_count integer [ not null, note: '盈利次数（realized_pnl > 0）' ]
	loss_count integer [ not null, note: '亏损次数（realized_pnl <= 0）' ]
	realized_pnl real [ not null, note: '月度总已实现盈亏（元）' ]
	average_return_rate real [ note: '本月平均收益率（小数）' ]
	max_gain real [ note: '最大单笔盈利（元）' ]
	max_loss real [ note: '最大单笔亏损（元）' ]
	generated_at varchar(255) [ not null, note: '汇总数据生成时间，ISO 8601格式；数据变化后需重新生成' ]

	Note: '月度复盘聚合缓存表。避免页面每次打开全量重算。数据有变化时需刷新 generated_at 并重算。'
}

// ---- 复盘系统外键关系 ----

Ref fk_trade_review_operation_review_id {
	trade_review_operation.review_id > trade_review_session.id [ delete: no action, update: cascade ]
}

Ref fk_trade_review_decision_note_review_id {
	trade_review_decision_note.review_id > trade_review_session.id [ delete: no action, update: cascade ]
}

Ref fk_trade_review_decision_note_operation_id {
	trade_review_decision_note.related_operation_id > trade_review_operation.id [ delete: set null, update: cascade ]
}

Ref fk_trade_review_ai_result_review_id {
	trade_review_ai_result.review_id > trade_review_session.id [ delete: no action, update: cascade ]
}

Ref fk_trade_review_session_stock_code {
	trade_review_session.stock_code > stock_list.code [ delete: no action, update: no action ]
}

// 股票关联关系数据结构设计

Table stock_linkage_backtest_job [headercolor: #8a5a00] {
  id varchar(255) [pk, unique, note: '回测任务ID，建议使用UUID。用于关联本次回测产生的触发事件、基准概率和统计结果。']
  job_name varchar(255) [note: '用户自定义任务名称，可为空；用于页面展示和人工识别。']
  a_select_mode varchar(255) [not null, note: 'A股票选择模式。manual_single表示用户指定单只A股票；hot_limit_top表示基于热点复盘选取近一年涨停次数Top N股票。']
  manual_a_full_code varchar(255) [note: '手动指定A股票时的完整股票代码，如000001.SZ；仅a_select_mode=manual_single时使用。']
  hot_top_n integer [note: '热点复盘高频涨停股数量，如20；仅a_select_mode=hot_limit_top时使用。']
  start_date date [not null, note: '回测开始日期，默认2025-01-01。']
  end_date date [not null, note: '回测结束日期；未手动选择时使用当前可用行情数据的最新交易日。']
  min_sample_count integer [not null, default: 30, note: '用户选择的最低样本数门槛，用于过滤或标记样本不足的统计结果。默认30。']
  status varchar(255) [not null, default: 'pending', note: '回测任务状态：pending/running/success/failed。']
  error_message text [note: '任务失败原因；成功时为空。']
  created_at datetime [not null, note: '任务创建时间。']
  updated_at datetime [not null, note: '任务最近更新时间。']
  finished_at datetime [note: '任务完成时间；未完成或失败前可为空。']

  indexes {
    (status, created_at) [name: 'idx_stock_linkage_job_status_created']
    (created_at) [name: 'idx_stock_linkage_job_created']
  }

  Note: '股票联动套利回测任务表。保存一次回测的参数、状态和生命周期信息。'
}

Table stock_linkage_trigger_event [headercolor: #8a5a00] {
  id varchar(255) [pk, unique, note: '触发事件ID，建议使用UUID。每条记录表示一次A股票触发事件。']
  job_id varchar(255) [not null, note: '所属回测任务ID，关联stock_linkage_backtest_job.id。']
  a_full_code varchar(255) [not null, note: '触发异动的A股票完整代码，如000001.SZ。']
  trade_date date [not null, note: '触发事件发生的交易日T。']
  bar_time datetime [not null, note: '触发事件所在5分钟K的时间。具体表示K线开始时间还是结束时间，需与5m_level_trade_data保持一致。']
  bar_index integer [not null, note: '触发事件所在交易日内的5分钟K序号，从1递增。用于定位t以及B股票t+1开盘价。']
  trigger_type varchar(255) [not null, note: '触发类型。single_bar_return表示单根5分钟K涨幅触发；intraday_return_from_pre_close表示盘中相对昨收累计涨幅触发。']
  trigger_threshold numeric [not null, note: '触发阈值，小数形式保存，如0.04表示4%。']
  trigger_return numeric [not null, note: '触发时实际涨幅，小数形式保存。single_bar_return时为当前K收盘相对当前K开盘涨幅；intraday_return_from_pre_close时为当前K收盘相对上一交易日收盘涨幅。']

  indexes {
    (job_id, a_full_code, trigger_type, trigger_threshold) [name: 'idx_stock_linkage_trigger_a_condition']
    (job_id, trade_date, bar_index) [name: 'idx_stock_linkage_trigger_time']
  }

  Note: '股票联动套利A股票触发事件表。用于复查A为何触发，并支撑样本数和触发覆盖率计算。'
}

Table stock_linkage_baseline_metric [headercolor: #8a5a00] {
  id varchar(255) [pk, unique, note: '基准指标ID，建议使用UUID。每条记录表示一个B股票在某观察口径和目标阈值下的自然上涨概率。']
  job_id varchar(255) [not null, note: '所属回测任务ID，关联stock_linkage_backtest_job.id。']
  b_full_code varchar(255) [not null, note: 'B股票完整代码，如000001.SZ。']
  observation_type varchar(255) [not null, note: 'B观察结果类型：t_day_high为T日触发后至收盘前最高价；t_day_close为T日收盘价；next_day_high为T+1交易日最高价；next_day_close为T+1交易日收盘价。']
  target_threshold numeric [not null, note: 'B目标涨幅阈值，小数形式保存，如0.03表示3%。']
  baseline_sample_count integer [not null, note: 'B自身有效模拟买入样本数。按同一回测区间内B所有有效5分钟K的下一根开盘价作为模拟买入点统计。']
  baseline_hit_count integer [not null, note: 'B自身达到目标阈值的次数。']
  baseline_probability numeric [not null, note: 'B自身基准概率，计算方式为baseline_hit_count / baseline_sample_count。']

  indexes {
    (job_id, b_full_code, observation_type, target_threshold) [name: 'uq_stock_linkage_baseline_b_metric', unique]
  }

  Note: 'B股票自身基准概率表。用于衡量B在没有指定A触发条件时达到同等涨幅目标的自然概率。'
}

Table stock_linkage_backtest_result [headercolor: #8a5a00] {
  id varchar(255) [pk, unique, note: '结果ID，建议使用UUID。每条记录表示一个A-B股票对在某触发条件、观察口径和目标阈值下的统计结果。']
  job_id varchar(255) [not null, note: '所属回测任务ID，关联stock_linkage_backtest_job.id。']
  a_full_code varchar(255) [not null, note: 'A股票完整代码，如000001.SZ。']
  b_full_code varchar(255) [not null, note: 'B股票完整代码，如000001.SZ。']
  trigger_type varchar(255) [not null, note: 'A触发类型。single_bar_return表示单根5分钟K涨幅触发；intraday_return_from_pre_close表示盘中相对昨收累计涨幅触发。']
  trigger_threshold numeric [not null, note: 'A触发阈值，小数形式保存，如0.04表示4%。']
  observation_type varchar(255) [not null, note: 'B观察结果类型：t_day_high为T日触发后至收盘前最高价；t_day_close为T日收盘价；next_day_high为T+1交易日最高价；next_day_close为T+1交易日收盘价。']
  target_threshold numeric [not null, note: 'B目标涨幅阈值，小数形式保存，如0.03表示3%。']
  sample_count integer [not null, note: 'A触发后，B有完整行情可观察的有效样本数。']
  hit_count integer [not null, note: '在有效样本中，B观察结果达到target_threshold的次数。']
  condition_probability numeric [not null, note: 'A触发条件下B达到目标阈值的条件概率，计算方式为hit_count / sample_count。']
  baseline_probability numeric [not null, note: 'B自身基准概率，来自stock_linkage_baseline_metric。']
  probability_lift numeric [not null, note: '概率提升，计算方式为condition_probability - baseline_probability。']
  lift_multiple numeric [note: '提升倍数，计算方式为condition_probability / baseline_probability；baseline_probability为0时可为空。']
  trigger_coverage_rate numeric [not null, note: '触发覆盖率，计算方式为触发交易日数 / 有效交易日数。']
  confidence_level varchar(255) [not null, note: '可信度等级：high/medium/low/insufficient。由样本数和触发覆盖率计算。']
  score numeric [not null, note: '默认排序综合分，计算方式为probability_lift * log(sample_count + 1)。']
  created_at datetime [not null, note: '结果记录创建时间。']

  indexes {
    (job_id, score) [name: 'idx_stock_linkage_result_job_score']
    (job_id, a_full_code, b_full_code) [name: 'idx_stock_linkage_result_pair']
    (job_id, trigger_type, trigger_threshold) [name: 'idx_stock_linkage_result_trigger']
    (job_id, observation_type, target_threshold) [name: 'idx_stock_linkage_result_observation']
  }

  Note: '股票联动套利回测结果表。用于页面查询、排序和展示A->B条件概率、基准概率、概率提升及可信度。'
}

Ref fk_stock_linkage_trigger_event_job {
  stock_linkage_trigger_event.job_id > stock_linkage_backtest_job.id [delete: no action, update: cascade]
}

Ref fk_stock_linkage_baseline_metric_job {
  stock_linkage_baseline_metric.job_id > stock_linkage_backtest_job.id [delete: no action, update: cascade]
}

Ref fk_stock_linkage_backtest_result_job {
  stock_linkage_backtest_result.job_id > stock_linkage_backtest_job.id [delete: no action, update: cascade]
}

// macd金叉趋势预警
Table macd_alert_result [headercolor: #7a3f8f] {
  id varchar(255) [pk, unique, note: '预警结果ID，建议使用UUID。']
  trade_date date [not null, note: '触发预警的交易日，YYYYMMDD。']
  stock_code varchar(255) [not null, note: '6位股票代码，如600545。']
  stock_name varchar(255) [not null, note: '股票名称，冗余保存便于展示历史结果。']
  pattern_key varchar(255) [not null, note: '形态键，第一版为golden_cross_setup。']
  pattern_name varchar(255) [not null, note: '形态展示名称，如金叉临界。']
  cross_zone varchar(255) [not null, note: '预警日金叉位置类型：underwater/above_zero/mixed。']
  close_price numeric [not null, note: '预警日收盘价。']
  next_cross_trigger_price numeric [not null, note: '下一交易日形成金叉所需的最低收盘价。']
  cross_trigger_distance_pct numeric [not null, note: '金叉价相对预警日收盘价的涨跌幅，小数形式，如0.0262表示2.62%。']
  next_limit_up_price numeric [note: '按预警日收盘价和涨跌停规则估算的下一交易日涨停价；无法估算时为空。']
  cross_trigger_reachable boolean [not null, default: true, note: '金叉价在下一交易日是否理论可达；当金叉价高于涨停价时为false。']
  cross_trigger_unreachable_reason varchar(255) [note: '金叉价理论不可达原因，如above_limit_up；可达时为空。']
  next_trend_keep_price numeric [not null, note: '下一交易日维持金叉趋势所需的最低收盘价；达到该价表示绿柱继续缩短。']
  trend_keep_distance_pct numeric [not null, note: '趋势维持价相对预警日收盘价的涨跌幅，小数形式。']
  macd_dif numeric [not null, note: '预警日DIF值。']
  macd_dea numeric [not null, note: '预警日DEA值。']
  macd_hist numeric [not null, note: '预警日MACD柱值。']
  green_shrink_days integer [not null, default: 2, note: '连续绿柱缩短天数。']
  last_limit_up_date date [note: '该股预警日前最近一次涨停日期；近120日无涨停记录时为空。']
  last_limit_up_theme varchar(255) [note: '该股预警日前最近一次涨停复盘题材，来自daily_hot_info.hot_theme。']
  last_limit_up_days_ago integer [note: '最近一次涨停距预警日的交易日间隔。']
  theme_heat_window_days integer [not null, default: 5, note: '题材活跃度统计窗口交易日数。']
  theme_recent_limit_up_count integer [not null, default: 0, note: '该题材在统计窗口内的去重涨停股票数。']
  theme_recent_rank integer [note: '该题材在统计窗口内按去重涨停股票数排序的排名；无题材时为空。']
  theme_heat_level varchar(255) [not null, default: 'none', note: '题材热度等级：strong/medium/weak/none。']
  next_track_date date [note: '下一次跟踪日期，通常为下一交易日；尚未跟踪时可为空。']
  track_status varchar(255) [not null, default: 'pending', note: '跟踪状态：pending/cross_confirmed/trend_kept/trend_weakened/data_missing。']
  tracked_close_price numeric [note: '跟踪日实际收盘价；尚未跟踪或缺数据时为空。']
  tracked_macd_dif numeric [note: '跟踪日DIF值；尚未跟踪或缺数据时为空。']
  tracked_macd_dea numeric [note: '跟踪日DEA值；尚未跟踪或缺数据时为空。']
  tracked_macd_hist numeric [note: '跟踪日MACD柱值；尚未跟踪或缺数据时为空。']
  tracked_at datetime [note: '跟踪计算时间；尚未跟踪时为空。']
  backtest_lookback_days integer [not null, default: 720, note: '预警内置回测回看交易日数量。']
  backtest_sample_count integer [not null, default: 0, note: '该标的历史同类形态样本数。']
  backtest_cross_success_count integer [not null, default: 0, note: '历史样本中5个交易日内形成金叉的次数。']
  backtest_cross_success_rate numeric [note: '历史样本金叉成功率。']
  backtest_t1_cross_confirmed_count integer [not null, default: 0, note: '历史样本中T+1已形成金叉的次数。']
  backtest_t1_trend_kept_count integer [not null, default: 0, note: '历史样本中T+1趋势维持的次数。']
  backtest_t1_trend_weakened_count integer [not null, default: 0, note: '历史样本中T+1趋势走弱的次数。']
  backtest_t1_trend_keep_rate numeric [note: '历史样本T+1趋势维持率。']
  backtest_completed_trade_count integer [not null, default: 0, note: '历史样本中完成买入和卖出的交易数。']
  backtest_profit_trade_count integer [not null, default: 0, note: '历史样本中收益率大于0的完成交易数。']
  backtest_win_rate numeric [note: '历史同类形态交易胜率。']
  backtest_avg_return_pct numeric [note: '历史同类形态平均收益率。']
  backtest_max_return_pct numeric [note: '历史同类形态最大收益率。']
  backtest_max_loss_pct numeric [note: '历史同类形态最大亏损率。']
  backtest_avg_holding_days numeric [note: '历史同类形态平均持有交易日数。']
  backtest_confidence_level varchar(255) [not null, default: 'insufficient', note: '回测可信度：high/medium/low/insufficient。']
  score numeric [not null, default: 0, note: '排序分，用于前端默认排序；可由临界价距离、绿柱缩短幅度、金叉价是否可达等计算。']
  summary text [not null, note: '面向用户展示的一句话预警摘要。']
  status varchar(255) [not null, default: 'active', note: '结果状态：active/ignored/archived。']
  created_at datetime [not null, note: '创建时间。']
  updated_at datetime [not null, note: '最近更新时间；重复扫描或跟踪覆盖结果时同步更新。']

  indexes {
    (trade_date, pattern_key, cross_zone) [name: 'idx_macd_alert_result_date_pattern_zone']
    (stock_code, trade_date) [name: 'idx_macd_alert_result_stock_date']
    (trade_date, score) [name: 'idx_macd_alert_result_date_score']
    (trade_date, stock_code, pattern_key, cross_zone) [name: 'uq_macd_alert_result_unique', unique]
  }

  Note: 'MACD日线形态预警结果表。保存每日收盘后扫描得到的金叉临界预警，支撑水下/水上金叉临界结果回看和前端列表展示。'
}

Table macd_alert_backtest_sample [headercolor: #7a3f8f] {
  id varchar(255) [pk, unique, note: '回测样本ID，建议使用UUID。']
  alert_result_id varchar(255) [not null, note: '所属预警结果ID，关联macd_alert_result.id。']
  stock_code varchar(255) [not null, note: '6位股票代码，如600545。']
  stock_name varchar(255) [not null, note: '股票名称，冗余保存便于展示。']
  alert_date date [not null, note: '预警日T，YYYYMMDD。']
  alert_close_price numeric [not null, note: '预警日收盘价。']
  next_cross_trigger_price numeric [not null, note: 'T+1形成金叉所需的最低收盘价。']
  cross_trigger_distance_pct numeric [not null, note: '金叉价相对预警日收盘价的涨跌幅，小数形式。']
  next_trend_keep_price numeric [not null, note: 'T+1维持金叉趋势所需的最低收盘价。']
  trend_keep_distance_pct numeric [not null, note: '趋势维持价相对预警日收盘价的涨跌幅，小数形式。']
  alert_macd_dif numeric [not null, note: '预警日DIF值。']
  alert_macd_dea numeric [not null, note: '预警日DEA值。']
  alert_macd_hist numeric [not null, note: '预警日MACD柱值。']
  alert_cross_zone varchar(255) [not null, note: '预警日金叉位置类型：underwater/above_zero/mixed。']
  last_limit_up_date date [note: '该股预警日前最近一次涨停日期；近120日无涨停记录时为空。']
  last_limit_up_theme varchar(255) [note: '该股预警日前最近一次涨停复盘题材。']
  last_limit_up_days_ago integer [note: '最近一次涨停距预警日的交易日间隔。']
  theme_heat_window_days integer [not null, default: 5, note: '题材活跃度统计窗口交易日数。']
  theme_recent_limit_up_count integer [not null, default: 0, note: '该题材在统计窗口内的去重涨停股票数。']
  theme_recent_rank integer [note: '该题材在统计窗口内按去重涨停股票数排序的排名；无题材时为空。']
  theme_heat_level varchar(255) [not null, default: 'none', note: '题材热度等级：strong/medium/weak/none。']
  buy_date date [note: '买入日，通常为T+1；数据不足时为空。']
  buy_price numeric [note: '买入价，取T+1开盘价。']
  t1_close_price numeric [note: 'T+1收盘价，用于验证金叉价和趋势维持价。']
  t1_track_status varchar(255) [note: 'T+1趋势验证状态：t1_cross_confirmed/t1_trend_kept/t1_trend_weakened/t1_data_missing。']
  t1_macd_dif numeric [note: 'T+1 DIF值。']
  t1_macd_dea numeric [note: 'T+1 DEA值。']
  t1_macd_hist numeric [note: 'T+1 MACD柱值。']
  cross_date date [note: '首次形成DIF>=DEA的日期；未金叉时为空。']
  cross_type varchar(255) [note: '实际金叉类型：underwater/above_zero/mixed/none。']
  sell_date date [note: '卖出日期；未完成交易时为空。']
  sell_price numeric [note: '卖出价格。']
  sell_reason varchar(255) [note: '卖出原因：red_shrink/timeout。']
  return_pct numeric [note: '收益率，小数形式，如0.05表示5%。']
  holding_days integer [note: '从买入到卖出的持有交易日数。']
  status varchar(255) [not null, note: '样本状态：pending_cross/cross_failed/cross_success/sold_by_red_shrink/sold_by_timeout/insufficient_data。']
  created_at datetime [not null, note: '记录创建时间。']

  indexes {
    (alert_result_id, alert_date) [name: 'idx_macd_alert_sample_result_date']
    (alert_result_id, return_pct) [name: 'idx_macd_alert_sample_result_return']
    (stock_code, alert_date) [name: 'idx_macd_alert_sample_stock_date']
  }

  Note: 'MACD形态预警内置回测样本表。每条记录表示某条预警结果对应的一次历史同类形态样本。'
}

Table macd_alert_report [headercolor: #7a3f8f] {
  id varchar(255) [pk, unique, note: '报告ID，建议使用UUID。']
  report_type varchar(255) [not null, note: '报告类型：daily_scan/daily_tracking/daily_brief/backtest。']
  trade_date date [note: '报告对应交易日；回测报告可为空。']
  source_trade_date date [note: '跟踪报告对应的来源预警日；非跟踪报告可为空。']
  alert_result_id varchar(255) [note: '单条预警报告关联的预警结果ID；非单条预警报告可为空。']
  html_file_path text [note: 'HTML报告文件相对路径，如data/reports/macd-alert/2026-06-05/brief-report.html。']
  pdf_file_path text [note: 'PDF报告文件相对路径，如data/reports/macd-alert/2026-06-05/brief-report.pdf。']
  csv_file_path text [note: 'CSV明细文件相对路径；未生成CSV时为空。']
  formats_json text [not null, note: '已生成格式JSON数组，如["html","pdf"]。']
  title varchar(255) [not null, note: '报告标题。']
  summary text [note: '报告摘要，便于列表展示。']
  created_at datetime [not null, note: '报告生成时间。']

  indexes {
    (report_type, trade_date) [name: 'idx_macd_alert_report_type_date']
    (alert_result_id) [name: 'idx_macd_alert_report_alert_result']
  }

  Note: 'MACD预警报告文件索引表。报告按需生成，保存HTML/PDF/CSV文件路径，便于前端和MCP返回报告引用。'
}

Ref fk_macd_alert_result_stock_code {
  macd_alert_result.stock_code > stock_list.code [delete: no action, update: no action]
}

Ref fk_macd_alert_backtest_sample_alert_result {
  macd_alert_backtest_sample.alert_result_id > macd_alert_result.id [delete: no action, update: cascade]
}

Ref fk_macd_alert_backtest_sample_stock_code {
  macd_alert_backtest_sample.stock_code > stock_list.code [delete: no action, update: no action]
}

Ref fk_macd_alert_report_alert_result {
  macd_alert_report.alert_result_id > macd_alert_result.id [delete: set null, update: cascade]
}
